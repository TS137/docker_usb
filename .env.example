# Camera device path (usually /dev/video0)
CAMERA_DEVICE=/dev/video0

# Capture resolution
RESOLUTION=1280x720

# Capture framerate
FRAMERATE=30

# Video bitrate
BITRATE=2000k

# Local RTMP target (Nginx container)
RTMP_TARGET=rtmp://nginx-rtmp:1935/live/stream

# External RTMP target (optional, leave empty to disable)
# EXTRA_RTMP_TARGET=rtmp://192.168.1.100:1935/live/external

# Nginx HTTP port for web preview
NGINX_HTTP_PORT=8080

# Nginx RTMP ingest port
NGINX_RTMP_PORT=1935
